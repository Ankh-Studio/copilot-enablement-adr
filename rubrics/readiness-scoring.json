  "confidenceLevels": {
    "high": {
      "description": "Strong evidence with multiple data points",
      "threshold": 0.8,
      "indicators": [
        "Direct file evidence",
        "Multiple corroborating sources",
        "Clear patterns"
      ]
    },
    "medium": {
      "description": "Moderate evidence with some assumptions",
      "threshold": 0.6,
      "indicators": [
        "Indirect evidence",
        "Single source",
        "Reasonable inferences"
      ]
    },
    "low": {
      "description": "Limited evidence with significant assumptions",
      "threshold": 0.4,
      "indicators": [
        "No direct evidence",
        "Multiple assumptions",
        "Speculative conclusions"
      ]
    }
  },
